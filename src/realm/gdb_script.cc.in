//
// Auto-generated by CMake from gdb_script.cc.in.  Embeds the realm-gdb.py
// source into librealm's .debug_gdb_scripts ELF section so that gdb
// auto-loads it whenever librealm is mapped into a debuggee.
//
// The byte array below is assembled at configure time by CMake.  Per gdb's
// "The .debug_gdb_scripts section" docs, each entry consists of:
//   * a 1-byte type tag (0x04 = SECTION_SCRIPT_ID_PYTHON_TEXT),
//   * the script name (no whitespace), terminated by a newline (0x0a),
//   * the script body,
//   * a NUL byte (0x00) terminating the entry.
// All four are concatenated into REALM_GDB_PAYLOAD_C_LITERAL by CMake.
//
// ELF only.  The CMake build only compiles this file on Linux/FreeBSD; the
// #if below is a belt-and-suspenders guard against accidental inclusion
// elsewhere (the section attribute would misbehave on Mach-O / PE).

#if defined(__linux__) || defined(__FreeBSD__)

__attribute__((section(".debug_gdb_scripts"), used))
static const unsigned char realm_gdb_script_section_data[] = {
    @REALM_GDB_PAYLOAD_C_LITERAL@
};

// Anchor symbol: when librealm is consumed as a static archive
// (librealm.a), the linker only pulls in object files that satisfy an
// undefined reference.  threads.cc takes the address of this symbol so
// this translation unit (and its .debug_gdb_scripts contribution) is
// always included.
extern "C" {
int realm_gdb_script_anchor = 0;
}

#endif
