//
// Auto-generated by CMake from gdb_script.cc.in.  Embeds the Python source of
// realm-gdb.py into the ELF .debug_gdb_scripts section so that gdb auto-loads
// it whenever librealm is mapped into a debuggee.  See gdb's "Auto-loading
// extensions" docs for the section format.
//
// Linux/FreeBSD ELF only -- guarded so this file is harmless if it is built
// elsewhere.

#if defined(__linux__) || defined(__FreeBSD__)

__asm__(
    ".pushsection \".debug_gdb_scripts\", \"MS\",@progbits,1\n"
    /* SECTION_SCRIPT_ID_PYTHON_TEXT == 4: inline python source follows */
    ".byte 4\n"
    /* script name -- terminated by newline (NOT NUL).  Must not contain
       whitespace.  See gdb's "The .debug_gdb_scripts section" docs. */
    ".ascii \"realm-gdb.py\\n\"\n"
    /* script body */
    ".incbin \"@REALM_GDB_PY_PATH@\"\n"
    /* trailing NUL that terminates the whole entry */
    ".byte 0\n"
    ".popsection\n");

// Anchor symbol: when librealm is consumed as a static archive (librealm.a),
// the linker only pulls in object files that satisfy an undefined reference.
// threads.cc takes the address of this symbol so this TU (and therefore the
// .debug_gdb_scripts contribution above) is always included.
extern "C" {
int realm_gdb_script_anchor = 0;
}

#endif
